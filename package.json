{
  "name": "obsidian-wiki-mcp",
  "version": "0.1.2",
  "description": "MCP server implementing Karpathy's LLM Wiki pattern for Obsidian vaults",
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "obsidian",
    "wiki",
    "knowledge-base",
    "llm",
    "claude"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aud1ence/obsidian-wiki-mcp"
  },
  "bin": {
    "obsidian-wiki-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node test/runner.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
